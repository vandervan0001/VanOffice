{
  "productName": "Team Foundry",
  "version": "0.1.0",
  "identifier": "com.vanoffice.team-foundry",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../.next"
  },
  "app": {
    "windows": [
      {
        "title": "Team Foundry",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "url": "http://localhost:3274"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
