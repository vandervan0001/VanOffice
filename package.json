{
  "name": "team-foundry",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev --webpack",
    "dev:turbo": "node ./node_modules/next/dist/bin/next dev",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "pretest": "npm run clean:metadata",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "pretest:watch": "npm run clean:metadata",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "clean:metadata": "find . -path './node_modules' -prune -o -name '._*' -delete",
    "clean:next": "rm -rf .next"
  },
  "dependencies": {
    "@pixi/react": "^8.0.5",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "get-proto": "^1.0.1",
    "nanoid": "^5.1.7",
    "next": "^16.1.7",
    "pixi.js": "^8.17.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.7",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
