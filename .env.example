# Team Foundry provider configuration

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# Optional local data path override
# TEAM_FOUNDRY_DATA_DIR=/absolute/path/to/data

# Paperclip AI sidecar (optional — enables real multi-agent orchestration)
# Start Paperclip with: npx paperclipai onboard --yes
# PAPERCLIP_URL=http://localhost:3100
